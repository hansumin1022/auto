cd ~/AUTOSAR_IN_ERIKA3
cat > Makefile << 'EOF'
CC = gcc
CFLAGS = -Wall -Wextra -g -DSIMULATION_MODE
SRCS = main.c rte.c swc_landingswitch.c swc_droneheating.c
TARGET = drone_system_sim
ERIKA3_DIR = $(HOME)/Downloads/erika3

.PHONY: sim
sim:
	@echo "===================================="
	@echo " 시뮬레이션 빌드 시작"
	@echo "===================================="
	$(CC) $(CFLAGS) $(SRCS) -o $(TARGET) -lrt
	@echo "===================================="
	@echo " 빌드 완료! 실행 시작"
	@echo "===================================="
	./$(TARGET)

.PHONY: build
build:
	$(CC) $(CFLAGS) $(SRCS) -o $(TARGET) -lrt
	@echo "빌드 완료: ./$(TARGET)"

.PHONY: run
run:
	./$(TARGET)

.PHONY: clean
clean:
	rm -f $(TARGET) *.o
	@echo "삭제 완료"

.PHONY: erika
erika:
	@mkdir -p build
	@cp conf.oil build/
	@cp *.c *.h build/
	cd build && cmake $(ERIKA3_DIR) \
	    -DERIKA3_OIL_FILES=$(PWD)/build/conf.oil \
	    -DCMAKE_BUILD_TYPE=Debug
	cd build && make
EOF
